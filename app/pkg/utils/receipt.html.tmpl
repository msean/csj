<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:"WenQuanYi Micro Hei","Noto Sans CJK SC","PingFang SC","SimHei",sans-serif;font-size:14px;color:#111;background:#fff;padding:32px 40px;width:700px;}
.header-top{text-align:center;font-size:12px;color:#555;line-height:1.6;}
.title-main{text-align:center;font-size:22px;font-weight:bold;margin:8px 0 16px;}
.meta-row{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;}
.meta-left{font-size:13px;color:#555;}
.customer-name{font-size:20px;font-weight:bold;margin:2px 0 8px;}
.meta-right{text-align:right;font-size:13px;}
.meta-right .serial{text-decoration:underline;font-weight:bold;}
.meta-right .date{text-decoration:underline;}
hr.thick{border:none;border-top:1.5px solid #111;margin:6px 0;}
hr.thin{border:none;border-top:0.5px solid #999;margin:4px 0;}
table{width:100%;border-collapse:collapse;margin:8px 0;}
table thead tr th{font-size:13px;color:#555;font-weight:normal;padding:4px 4px;}
table tbody tr td{padding:6px 4px;font-size:14px;font-weight:bold;border-bottom:0.5px solid #ddd;}
table tbody tr td:nth-child(1){color:#555;font-weight:normal;width:6%;}
table tbody tr td:nth-child(2){width:24%;}
table tbody tr td:nth-child(3){text-align:center;width:14%;}
table tbody tr td:nth-child(4){text-align:center;width:14%;}
table tbody tr td:nth-child(5){text-align:center;width:14%;}
table tbody tr td:nth-child(6){text-align:right;width:18%;}
table tfoot tr td{padding:6px 4px;font-size:14px;font-weight:bold;}
table tfoot tr td:nth-child(6){text-align:right;}
.spacer{height:32px;}
.summary{text-align:right;font-size:16px;margin:4px 0;}
.summary-row{display:flex;justify-content:flex-end;gap:32px;margin:4px 0;font-size:16px;}
hr.bold{border:none;border-top:2px solid #111;margin:8px 0;}
.bottom-bar{display:flex;justify-content:space-between;align-items:center;margin-top:4px;}
.prev-debt{font-size:18px;font-weight:bold;}
.total-debt{font-size:18px;font-weight:bold;}
.contact{font-size:12px;color:#333;margin-top:14px;line-height:1.8;}
.footer-brand{display:flex;align-items:center;gap:10px;margin-top:12px;border-top:1px solid #ccc;padding-top:10px;font-size:12px;color:#888;}
.footer-brand .logo-box{border:1.5px solid #999;padding:4px 8px;font-size:16px;font-weight:bold;color:#555;}
</style>
</head>
<body>
<div class="header-top">
  <div>赊欠凭证</div>
  <div>广东省食用农产品批发市场销售票据</div>
</div>

<div class="title-main">{{.Title}}</div>

<div class="meta-row">
  <div>
    <div class="meta-left">客户:</div>
    <div class="customer-name">{{.CustomerName}}</div>
  </div>
  <div class="meta-right">
    <div>票号：<span class="serial">{{.SerialNo}}</span></div>
    <div><span class="date">{{.Date}}</span></div>
  </div>
</div>

<hr class="thick"/>

<table>
  <thead>
    <tr>
      <th>#</th>
      <th>货品</th>
      <th>数量</th>
      <th>重量</th>
      <th>单价</th>
      <th>小计</th>
    </tr>
  </thead>
  <tbody>
    {{range $i, $g := .GoodsList}}
    <tr>
      <td>{{add $i 1}}</td>
      <td>{{$g.GoodsName}}</td>
      <td>{{$g.MountStr}}</td>
      <td>{{$g.WeightStr}}</td>
      <td>{{$g.PriceStr}}</td>
      <td>{{$g.TotalStr}}</td>
    </tr>
    {{end}}
  </tbody>
  <tfoot>
    <tr>
      <td></td>
      <td style="font-weight:bold;">合计</td>
      <td style="text-align:center;font-weight:bold;">{{.TotalMount}}</td>
      <td style="text-align:center;font-weight:bold;">{{.TotalWeight}}</td>
      <td></td>
      <td style="text-align:right;font-weight:bold;">{{.TotalAmountStr}}</td>
    </tr>
  </tfoot>
</table>

<hr class="thin"/>
<div class="spacer"></div>

<div class="summary-row">
  <span>今日赊欠：</span>
  <span>{{.CreditAmountStr}}</span>
</div>
<div class="summary-row">
  <span>前欠：</span>
  <span>{{.TotalPreviousCreditStr}}</span>
</div>

<hr class="bold"/>

<div class="bottom-bar">
  <div class="prev-debt">前欠: <strong>{{.TotalPreviousCreditStr}}</strong></div>
  <div class="total-debt">总欠: <strong>{{.TotalDebtStr}}</strong></div>
</div>

<hr class="thin"/>

<div class="contact">{{.Contact}}</div>

</body>
</html>
